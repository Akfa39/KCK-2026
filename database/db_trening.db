
PRAGMA foreign_keys = ON;
-- Konta użytkowników aplikacji
CREATE TABLE IF NOT EXISTS TBL_Users (
    id   INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL,
    user VARCHAR(100) NOT NULL UNIQUE,
    role VARCHAR(10) NOT NULL DEFAULT 'user'
         CHECK (role IN ('user', 'admin'))
);


-- Ustawienia i dane użytkownika
CREATE TABLE IF NOT EXISTS TBL_User_Settings (
    user_id     INTEGER PRIMARY KEY,
    language    VARCHAR(3)  DEFAULT 'pl',
    unit_system VARCHAR(8)  NOT NULL DEFAULT 'metric'
                CHECK (unit_system IN ('metric', 'imperial')),
    weight_kg   REAL,
    height_cm   REAL,
    birth_date  DATE,
    gender      CHAR(1) CHECK (gender IN ('M', 'F')),
    FOREIGN KEY (user_id) REFERENCES TBL_Users(id) ON DELETE CASCADE
);


-- Katalog ćwiczeń
CREATE TABLE IF NOT EXISTS TBL_Exercises (
    id           INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id      INTEGER,
    name         VARCHAR(30) NOT NULL,
    description  TEXT,
    muscle_group VARCHAR(50),
    equipment    VARCHAR(50),
    difficulty   INTEGER CHECK (difficulty IN (1, 2, 3)),  -- 1=easy, 2=medium, 3=hard
    image_url    VARCHAR(100),
    video_url    VARCHAR(100),
    FOREIGN KEY (user_id) REFERENCES TBL_Users(id) ON DELETE SET NULL
);


-- Zapisane plany treningowe
CREATE TABLE IF NOT EXISTS TBL_Training_Plans (
    id      INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER      NOT NULL,
    name    VARCHAR(100) NOT NULL,
    FOREIGN KEY (user_id) REFERENCES TBL_Users(id) ON DELETE CASCADE
);


-- Pozycje w planie treningowym
CREATE TABLE IF NOT EXISTS TBL_Training_Plan_Exercises (
    id                      INTEGER PRIMARY KEY AUTOINCREMENT,
    plan_id                 INTEGER NOT NULL,
    exercise_id             INTEGER NOT NULL,
    order_index             INTEGER NOT NULL,
    sets                    INTEGER NOT NULL CHECK (sets > 0),
    target_reps             INTEGER,
    target_duration_seconds INTEGER,
    FOREIGN KEY (plan_id)     REFERENCES TBL_Training_Plans(id) ON DELETE CASCADE,
    FOREIGN KEY (exercise_id) REFERENCES TBL_Exercises(id)
);


-- Historia treningów
CREATE TABLE IF NOT EXISTS TBL_Workouts (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id         INTEGER NOT NULL,
    plan_id         INTEGER,
    started_at      TEXT    NOT NULL,  -- format ISO 8601: 'YYYY-MM-DD HH:MM:SS'
    ended_at        TEXT,               -- format ISO 8601: 'YYYY-MM-DD HH:MM:SS'
    calories_burned INTEGER,
    FOREIGN KEY (user_id) REFERENCES TBL_Users(id) ON DELETE CASCADE,
    FOREIGN KEY (plan_id) REFERENCES TBL_Training_Plans(id) ON DELETE SET NULL
);


-- Szczegóły wykonanych ćwiczeń
CREATE TABLE IF NOT EXISTS TBL_Workout_Exercises (
    id               INTEGER PRIMARY KEY AUTOINCREMENT,
    workout_id       INTEGER NOT NULL,
    exercise_id      INTEGER NOT NULL,
    set_number       INTEGER NOT NULL DEFAULT 1,
    reps_completed   INTEGER,
    duration_seconds INTEGER,
    FOREIGN KEY (workout_id)  REFERENCES TBL_Workouts(id)  ON DELETE CASCADE,
    FOREIGN KEY (exercise_id) REFERENCES TBL_Exercises(id)
);

